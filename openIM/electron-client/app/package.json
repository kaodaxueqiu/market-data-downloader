{
  "name": "G-Snowball-IM",
  "version": "1.0.5",
  "main": "dist-electron/main/index.js",
  "description": "G-Snowball IM Client.",
  "author": "ZiZhou",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/kaodaxueqiu/market-data-downloader"
  },
  "workspaces": [
    "packages/*"
  ],
  "homepage": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite --force --host",
    "setup:ffi": "pnpm --filter @openim/build-tooling run install-ffi-assets",
    "build:packages": "pnpm -r --filter \"./packages/*\" --if-present run build",
    "dev:packages": "pnpm -r --filter \"./packages/*\" --if-present run dev",
    "build": "pnpm typecheck && vite build",
    "build:prod": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "set:version:prod": "pnpm --filter @openim/build-tooling run set-version -- prod",
    "set:version:dev": "pnpm --filter @openim/build-tooling run set-version -- dev",
    "prepare:prod": "pnpm --filter @openim/build-tooling run prepare-package -- prod",
    "prepare:dev": "pnpm --filter @openim/build-tooling run prepare-package -- dev",
    "restore:package": "pnpm --filter @openim/build-tooling run restore-package",
    "electron:build": "pnpm --filter @openim/build-tooling run electron-build",
    "electron:build:dev": "pnpm --filter @openim/build-tooling run electron-build -- --mode dev",
    "electron:build:prod": "node scripts/install-ffi.js && pnpm build:packages && pnpm --filter @openim/build-tooling run electron-build -- --mode prod",
    "electron:build:prod:all": "pnpm --filter @openim/build-tooling run electron-build -- --mode prod --all",
    "release:prod:web": "export BUILD_TARGET=web && pnpm run build:prod",
    "release:prod:all": "pnpm --filter @openim/build-tooling run release-all",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint --fix --quiet src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash-es": "^4.17.12",
    "@types/md5": "^2.3.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^9.0.1",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^22.3.27",
    "electron-builder": "^23.6.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.14.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.21",
    "postcss-nesting": "^12.0.2",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "sass": "^1.58.3",
    "tailwindcss": "^4.1.18",
    "terser": "^5.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.21",
    "vite-electron-plugin": "^0.8.2",
    "vite-plugin-electron": "^0.11.1"
  },
  "engines": {
    "node": "^14.18.0 || >=16.0.0"
  },
  "lint-staged": {
    "src/**/*.{tsx,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,html,css,scss,xml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^5.1.4",
    "@openim/electron-capturer": "workspace:*",
    "@openim/electron-client-sdk": "3.8.5",
    "@openim/im-composer": "workspace:*",
    "@openim/shared": "workspace:*",
    "@openim/wasm-client-sdk": "3.8.5",
    "@tanstack/react-query": "^5.90.19",
    "adm-zip": "^0.5.10",
    "ahooks": "3.7.7",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "antd": "5.10.0",
    "axios": "^1.4.0",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.7",
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^5.3.0",
    "emoji-picker-element": "1.21.3",
    "i18next": "^22.5.0",
    "i18next-browser-languagedetector": "^7.0.2",
    "i18next-fs-backend": "^2.2.0",
    "localforage": "^1.10.0",
    "md5": "^2.3.0",
    "mitt": "^3.0.0",
    "node-fetch": "^3.3.2",
    "react-draggable": "^4.4.5",
    "react-i18next": "^12.3.1",
    "react-image-file-resizer": "^0.4.8",
    "react-markdown": "^10.0.1",
    "react-player": "^2.16.1",
    "react-resizable-panels": "^4.4.1",
    "react-router-dom": "^6.11.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-use": "^17.4.0",
    "react-virtuoso": "4.3.8",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sudo-prompt": "^9.2.1",
    "uuid": "^9.0.1",
    "zustand": "^4.3.3"
  }
}

