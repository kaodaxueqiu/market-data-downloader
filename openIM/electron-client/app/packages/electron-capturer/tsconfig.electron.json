{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "build",
    "rootDir": ".",
    "allowJs": false,
    "esModuleInterop": true,
    "types": ["node", "electron"]
  },
  "include": ["src/electron/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["dist-electron", "dist-web", "node_modules"]
}
